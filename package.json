    "@mediapipe/hands": "^0.4.1675469240",
    "@stream-io/video-react-sdk": "^1.32.4",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "buffer": "^6.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
